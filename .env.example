# SMTP Configuration
SMTP_PORT=2525
SMTP_HOST=0.0.0.0
# Set to true if you have SSL certificates
SMTP_TLS=false
# Paths to your SSL certificates (required if SMTP_TLS=true)
# TLS_KEY_PATH=/path/to/privkey.pem
# TLS_CERT_PATH=/path/to/fullchain.pem

# Web Configuration
PORT=3000
DOMAIN=yourdomain.com

# Security
# Comma separated list of allowed origins (e.g. https://yourdomain.com,https://another.com)
# Platform domains (*.run.app) are automatically allowed.
ALLOWED_ORIGINS=
# Comma separated list of forbidden prefixes
KEYWORD_BLACKLIST=admin,root,postmaster,webmaster,system
# Custom security notices separated by | (pipe)
# SECURITY_NOTICE=Notice 1|Notice 2|Notice 3
