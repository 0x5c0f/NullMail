# SMTP Configuration
SMTP_PORT=2525
SMTPS_PORT=465
SMTP_HOST=0.0.0.0
# Maximum accepted message size in bytes
SMTP_MAX_SIZE=10485760
# Configure both paths to enable STARTTLS on SMTP and SMTPS on SMTPS_PORT
# TLS_KEY_PATH=/path/to/privkey.pem
# TLS_CERT_PATH=/path/to/fullchain.pem

# Web Configuration
PORT=3000
DOMAIN=yourdomain.com

# Security
# Comma separated list of exact allowed origins (e.g. https://app.yourdomain.com)
ALLOWED_ORIGINS=
# Comma separated list of forbidden prefixes
KEYWORD_BLACKLIST=admin,root,postmaster,webmaster,system
# Custom security notices separated by | (pipe)
# SECURITY_NOTICE=Notice 1|Notice 2|Notice 3
